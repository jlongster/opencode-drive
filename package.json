{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "opencode-drive",
  "version": "0.1.0",
  "description": "Drive real and simulated OpenCode instances",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "bin": {
    "opencode-drive": "./bin/opencode-drive"
  },
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client/index.ts"
  },
  "files": [
    "bin/opencode-drive",
    "src/cli",
    "src/client",
    "src/campaign-api.ts",
    "src/drive.ts",
    "src/index.ts",
    "README.md"
  ],
  "scripts": {
    "drive": "bun run src/cli/index.ts",
    "campaign": "bun run src/campaign.ts",
    "sim:client": "bun run src/sim-client.ts",
    "reproduce:stale-running": "bun run src/reproduce-stale-running.ts",
    "reproduce:stale-running:visible": "bun run src/reproduce-stale-running-visible.ts",
    "reproduce:self-signed-provider": "bun run src/reproduce-self-signed-provider.ts",
    "lint": "oxlint src",
    "test": "bun test test/cli/parse.test.ts test/cli/integration.test.ts",
    "typecheck:drive": "tsgo --noEmit -p tsconfig.drive.json",
    "typecheck": "tsgo --noEmit",
    "check": "bun run lint && bun run typecheck",
    "update:opencode": "git -C opencode-latest pull --ff-only && bun --cwd opencode-latest install",
    "reproduce:provider-catalog-race:visible": "bun run src/reproduce-provider-catalog-race-visible.ts"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.93",
    "@effect/platform-node-shared": "4.0.0-beta.93",
    "effect": "4.0.0-beta.93"
  },
  "devDependencies": {
    "@tsconfig/bun": "1.0.9",
    "@types/bun": "1.3.13",
    "@typescript/native-preview": "7.0.0-dev.20251207.1",
    "oxlint": "1.60.0",
    "oxlint-tsgolint": "0.21.0",
    "typescript": "5.8.2"
  }
}
