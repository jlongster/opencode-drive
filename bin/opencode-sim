#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'EOF'
usage: opencode-sim [--state DIR] [--renderer fake|visible] [--anchor DIR]
                    [--driver COMMAND] [--ui-port PORT] [--backend-port PORT]
                    -- COMMAND [ARGS...]

Creates an isolated simulation anchor, exports the environment variables
opencode needs, changes into the anchor, and runs COMMAND.

Defaults:
  --state  /tmp/opencode-sim-state
  --anchor /tmp/opencode-sim-anchor

When --driver is provided, opencode-sim assigns exact frontend/backend control
ports, exports OPENCODE_SIMULATION_UI_WS and OPENCODE_SIMULATION_BACKEND_WS,
waits for both sockets, then runs the driver command in the background.
EOF
}

free_port() {
  local port=""
  for _ in {1..100}; do
    port=$((20000 + RANDOM % 40000))
    if ! (exec 3<>"/dev/tcp/127.0.0.1/$port") 2>/dev/null; then
      printf '%s\n' "$port"
      return 0
    fi
  done
  echo "failed to find a free local port" >&2
  return 1
}

sim_log() {
  local type="$1"
  local data="${2:-{}}"
  printf '{"time":"%s","pid":%s,"type":"%s","data":%s}\n' \
    "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$$" "$type" "$data" >> "${OPENCODE_SIMULATION_LOG:-/tmp/opencode-simulation.log}"
}

wait_port() {
  local label="$1"
  local port="$2"
  local deadline=$((SECONDS + 60))
  while (( SECONDS < deadline )); do
    if (exec 3<>"/dev/tcp/127.0.0.1/$port") 2>/dev/null; then
      exec 3>&- 3<&-
      return 0
    fi
    sleep 0.1
  done
  echo "timed out waiting for $label simulation websocket on 127.0.0.1:$port" >&2
  return 1
}

state="/tmp/opencode-sim-state"
renderer=""
anchor="/tmp/opencode-sim-anchor"
driver=""
ui_port=""
backend_port=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --state)
      state="${2:-}"
      shift 2
      ;;
    --renderer)
      renderer="${2:-}"
      shift 2
      ;;
    --anchor)
      anchor="${2:-}"
      shift 2
      ;;
    --driver)
      driver="${2:-}"
      shift 2
      ;;
    --ui-port)
      ui_port="${2:-}"
      shift 2
      ;;
    --backend-port)
      backend_port="${2:-}"
      shift 2
      ;;
    --)
      shift
      break
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "unknown argument: $1" >&2
      usage
      exit 2
      ;;
  esac
done

if [[ $# -eq 0 ]]; then
  usage
  exit 2
fi

mkdir -p "$anchor"

export OPENCODE_SIMULATION=1
export OPENCODE_SIMULATION_ROOT="$anchor"
export OPENCODE_CONFIG_DIR="$anchor/.config/opencode"
export OPENCODE_TEST_HOME="$anchor"
export XDG_DATA_HOME="$anchor/.local/share"
export XDG_CACHE_HOME="$anchor/.cache"
export XDG_STATE_HOME="$anchor/.local/state"
export XDG_CONFIG_HOME="$anchor/.config"
export OPENCODE_DB=":memory:"

if [[ -n "$state" ]]; then
  export OPENCODE_SIMULATION_STATE="$state"
fi

if [[ -n "$renderer" ]]; then
  export OPENCODE_SIMULATION_RENDERER="$renderer"
fi

if [[ -n "$driver" ]]; then
  if [[ -z "$ui_port" ]]; then
    ui_port="$(free_port)"
  fi
  if [[ -z "$backend_port" ]]; then
    backend_port="$(free_port)"
  fi
  while [[ "$backend_port" == "$ui_port" ]]; do
    backend_port="$(free_port)"
  done
fi

if [[ -n "$ui_port" ]]; then
  export OPENCODE_SIMULATION_UI_PORT="$ui_port"
  export OPENCODE_SIMULATION_UI_WS="ws://127.0.0.1:$ui_port"
fi

if [[ -n "$backend_port" ]]; then
  export OPENCODE_SIMULATION_BACKEND_PORT="$backend_port"
  export OPENCODE_SIMULATION_BACKEND_WS="ws://127.0.0.1:$backend_port"
fi

# Start each run with a fresh simulation log. Clearing here (not in the app)
# is deliberate: the TUI and the standalone server child both append to this
# file, and whichever process starts later would wipe the other's entries if
# they truncated on their own startup.
: > "${OPENCODE_SIMULATION_LOG:-/tmp/opencode-simulation.log}"
: > "${OPENCODE_SIMULATION_DRIVER_LOG:-/tmp/opencode-simulation-driver.log}"
sim_log "wrapper.start" "{\"state\":\"$state\",\"anchor\":\"$anchor\",\"renderer\":\"$renderer\",\"driver\":$([[ -n "$driver" ]] && printf true || printf false),\"uiPort\":\"$ui_port\",\"backendPort\":\"$backend_port\"}"

mkdir -p "$OPENCODE_CONFIG_DIR" "$XDG_DATA_HOME" "$XDG_CACHE_HOME" "$XDG_STATE_HOME" "$XDG_CONFIG_HOME"
mkdir -p "$XDG_STATE_HOME/opencode"
if [[ ! -f "$XDG_STATE_HOME/opencode/kv.json" ]]; then
  printf '{}' > "$XDG_STATE_HOME/opencode/kv.json"
fi
cd "$anchor"

driver_pid=""
app_pid=""
restore_terminal() {
  if [[ -t 0 ]]; then
    while IFS= read -r -s -t 0.01 -n 1024 _; do
      :
    done
  fi
  printf '\033[0m\033[?25h\033[?1049l\033[?2004l\033[?1000l\033[?1002l\033[?1003l\033[?1006l'
}

cleanup() {
  if [[ -n "$driver_pid" ]]; then
    kill "$driver_pid" 2>/dev/null || true
    wait "$driver_pid" 2>/dev/null || true
  fi
  if [[ -n "$app_pid" ]]; then
    kill -INT "$app_pid" 2>/dev/null || true
    for _ in {1..20}; do
      if ! kill -0 "$app_pid" 2>/dev/null; then
        break
      fi
      sleep 0.1
    done
    kill "$app_pid" 2>/dev/null || true
    wait "$app_pid" 2>/dev/null || true
  fi
  restore_terminal
}

if [[ -n "$driver" ]]; then
  (
    sim_log "wrapper.driver.wait" "{\"uiPort\":\"$ui_port\",\"backendPort\":\"$backend_port\"}"
    wait_port frontend "$ui_port"
    sim_log "wrapper.driver.frontend-ready" "{\"url\":\"${OPENCODE_SIMULATION_UI_WS:-}\"}"
    wait_port backend "$backend_port"
    sim_log "wrapper.driver.backend-ready" "{\"url\":\"${OPENCODE_SIMULATION_BACKEND_WS:-}\"}"
    sim_log "wrapper.driver.start" "{\"log\":\"${OPENCODE_SIMULATION_DRIVER_LOG:-/tmp/opencode-simulation-driver.log}\"}"
    set +e
    bash -lc "$driver" > "${OPENCODE_SIMULATION_DRIVER_LOG:-/tmp/opencode-simulation-driver.log}" 2>&1
    driver_status="$?"
    sim_log "wrapper.driver.exit" "{\"status\":$driver_status}"
    exit "$driver_status"
  ) &
  driver_pid="$!"
  trap cleanup EXIT INT TERM
  "$@" &
  app_pid="$!"
  set +e
  while kill -0 "$driver_pid" 2>/dev/null && kill -0 "$app_pid" 2>/dev/null; do
    sleep 0.2
  done
  if ! kill -0 "$driver_pid" 2>/dev/null; then
    wait "$driver_pid"
    status="$?"
  else
    wait "$app_pid"
    status="$?"
  fi
  set -e
  cleanup
  exit "$status"
fi

exec "$@"
