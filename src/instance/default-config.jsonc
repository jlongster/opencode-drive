{
  "model": "simulation/gpt-sim-model",
  "snapshots": false,
  "permissions": [
    {
      "action": "*",
      "resource": "*",
      "effect": "allow"
    }
  ],
  "providers": {
    "simulation": {
      "name": "Simulation",
      "package": "aisdk:@ai-sdk/openai-compatible",
      "settings": {
        "baseURL": "https://api.openai.com/v1"
      },
      "request": {
        "body": {
          "apiKey": "sim-key"
        }
      },
      "models": {
        "gpt-sim-model": {
          "name": "Simulated Model",
          "capabilities": {
            "tools": true,
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 128000,
            "output": 16000
          }
        }
      }
    }
  }
}
